<!DOCTYPE html>
<html lang="{{ lang }}" dir="{{ 'rtl' if lang == 'ar' else 'ltr' }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Vague de Goût</title>
  <meta name="description" content="{{ i18n.hero_desc[lang] }}">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Vague de Goût">
  <meta property="og:description" content="{{ i18n.hero_desc[lang] }}">
  <meta property="og:image" content="{{ '/assets/images/og-image.jpg' | url }}">

  <link rel="icon" type="image/png" href="{{ '/favicon.png' | url }}">
  <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Playfair+Display:ital,wght@0,700;1,700&family=Amiri:wght@400;700&display=swap" rel="stylesheet">
  
  {% if lang == 'ar' %}
  <style>
    body { font-family: 'Amiri', serif; }
    .category-title { border-left: none; border-right: 5px solid var(--accent); padding-left: 0; padding-right: 1rem; }
  </style>
  {% endif %}

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FoodEstablishment",
    "name": "Vague de Goût",
    "image": "https://marwankous.github.io/vague-de-gout/assets/images/logo.svg",
    "@id": "https://marwankous.github.io/vague-de-gout/",
    "url": "https://marwankous.github.io/vague-de-gout/",
    "telephone": "+212636925874",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Rabat",
      "addressCountry": "MA"
    },
    "menu": "https://marwankous.github.io/vague-de-gout/",
    "servesCuisine": "Seafood, Moroccan"
  }
  </script>
</head>
<body>
  <header>
    <div class="logo">
      <a href="{{ '/' | url }}{{ lang }}/">
        <img src="{{ '/assets/images/logo.svg' | url }}" alt="Vague de Goût" class="logo-img">
      </a>
    </div>
    <nav class="nav-links">
      <div class="lang-switcher">
        <a href="{{ '/' | url }}fr/" class="{{ 'active' if lang == 'fr' }}">FR</a>
        <a href="{{ '/' | url }}en/" class="{{ 'active' if lang == 'en' }}">EN</a>
        <a href="{{ '/' | url }}ar/" class="{{ 'active' if lang == 'ar' }}">AR</a>
      </div>
      <a href="https://instagram.com/vaguedegout" class="instagram-link" target="_blank">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
      </a>
    </nav>
  </header>

  {{ content | safe }}

  <section class="b2b-section">
    <h2>{{ i18n.b2b_title[lang] }}</h2>
    <p>{{ i18n.b2b_desc[lang] }}</p>
    <a href="mailto:vague.de.gout@gmail.com?subject={{ i18n.quote_btn[lang] | urlencode }}" class="quote-btn">{{ i18n.quote_btn[lang] }}</a>
  </section>

  <footer>
    <div class="footer-info">
      <p><strong>{{ i18n.hero_title[lang] }}</strong></p>
      <p>{{ i18n.footer_location[lang] }}</p>
      <p>Email: vague.de.gout@gmail.com</p>
      <p>WhatsApp: +212 636 92 58 74</p>
    </div>
    <p>&copy; 2026 {{ i18n.hero_title[lang] }}. {{ i18n.footer_rights[lang] }}</p>
  </footer>

  <!-- Floating Buttons -->
  <a href="https://wa.me/212636925874?text={{ i18n.whatsapp_info[lang] | urlencode }}" class="sticky-whatsapp" target="_blank" aria-label="WhatsApp">
    <span>💬</span>
  </a>

  <button class="scroll-top" id="scrollTop" aria-label="Scroll to top">
    ↑
  </button>

  <script>
    const scrollTopBtn = document.getElementById("scrollTop");
    
    window.onscroll = function() {
      if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
        scrollTopBtn.classList.add("show");
      } else {
        scrollTopBtn.classList.remove("show");
      }
    };

    scrollTopBtn.onclick = function() {
      window.scrollTo({
        top: 0,
        behavior: "smooth"
      });
    };
  </script>
</body>
</html>

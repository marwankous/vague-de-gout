		<style type="text/css" id="wp-custom-css">
			/* MV Bamboo Full-width template adjustment */
.page-template-page-full-width #content{
max-width: 1200px;
}
/* END MV Bamboo Full-width template adjustment */

.header-logo-container .dpsp-pin-it-button {
display:none !important;
}

.breadcrumbs a{
	color: #1e1e1e;
	}

.breadcrumbs {
	line-height: 1.2;
	padding-bottom: 10px;
}

.breadcrumbs a:hover{
	color: #b21711;
}

breadcrumbs {
	  font-size: 14px;
		text-align: left;
		margin-bottom: 50px;
}

h1 {
line-height: 1.4em!important;
font-size: 42px!important;
text-align: left;
margin-top: 20px;
}

.excerpt-photo img {border-radius: 0}

.article-meta a{
	color: #1e1e1e;
}

.article-meta a:hover{
	color: #b21711;
}

.article-meta {
	font-weight:500;
	font-size:14px;
	line-height:1.4;
	text-align: left;
	padding-bottom:30px;
}

.author-meta {
	padding-top: 20px;
}

#comment-count {
	padding-left: 20px;
}

.meta-cats {
	padding-top: 20px;
}

.the_excerpt {
	font-size: 20px;
}

/* .cat-links {
	display:none!important;
} */

.menu-item a{
	color: #1e1e1e !important;
}

.menu-item {
	padding-right: 8px;
	padding-left: 8px;
}

.menu-item:hover {
	background: #eeecec;
}

.sub-menu .menu-item a{
	font-size: 12px;
}

.sidebar a{
	color: #1e1e1e;
	font-size: 14px;
}

.sidebar a:hover {
	color: #b21711;
	font-weight: bold;
}

.widget_recent_entries li{
	line-height: 1.2;
	padding-bottom: 10px;
	border-bottom: 1px solid #cbc5c5;
}

.tags-links {
	font-size: 12px;
	line-height: 1;
	background: #eeecec;
}

body {   
	line-height : 1.7; }

.article-navigation {
	padding: 30px 0px
}
.wp-block-button:hover {
	background: #98806b;
}

.article-navigation-title {
	font-size: 20px;
}

.footer {
	background: #333745;
}

h3.widget-title {
	color: #cbc5c5;
}

.footer a{
	font-size: 14px;
	color: #cbc5c5;
}

.footer a:link { 
	text-decoration: none;
	color: #cbc5c5;
}
	
.footer a:hover {
	font-weight: bold;
	}

.footer li{
	line-height: 20px;
	margin-bottom: 20px;
}

.footer-copy {
	font-size: 14px;
	color: #cbc5c5;
}

.footer #footer_branding {

  color: #cbc5c5;

}

.cat-links a{ text-decoration:none; text-transform:uppercase; font-weight: 600;}

.catname{ margin-bottom:0px; text-align:left; line-height: 1;}
.cat-links{ font-size:14px;}

.article-meta .posted-on:after{ display:none;}

figure { border: 1px
solid #f0f0f0; padding:4px; text-align:center; display:inline-block; margin:0px auto; margin-bottom:10px;}

.wp-caption-text {
	margin-top: 10px;
}

figcaption {
	font-size: 11px;
	line-height: 17px; margin-bottom:5px;
}

.sidebar h3.widget-title{ color:#1e1e1e; font-size: 20px;}

#cat.postform{ font-size: 16px;}

@media (max-width:768px){
	.header-container{ text-align:left; display: flex;   align-items: center;}

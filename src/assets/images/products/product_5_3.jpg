<link rel='stylesheet' id='dpsp-frontend-style-pro-css' href='https://tasteofmaroc.com/wp-content/plugins/social-pug/assets/dist/style-frontend-pro.css?ver=2.29.1' type='text/css' media='all' />
<style id='dpsp-frontend-style-pro-inline-css' type='text/css'>

				@media screen and ( max-width : 720px ) {
					.dpsp-content-wrapper.dpsp-hide-on-mobile,
					.dpsp-share-text.dpsp-hide-on-mobile {
						display: none;
					}
					.dpsp-has-spacing .dpsp-networks-btns-wrapper li {
						margin:0 2% 10px 0;
					}
					.dpsp-network-btn.dpsp-has-label:not(.dpsp-has-count) {
						max-height: 40px;
						padding: 0;
						justify-content: center;
					}
					.dpsp-content-wrapper.dpsp-size-small .dpsp-network-btn.dpsp-has-label:not(.dpsp-has-count){
						max-height: 32px;
					}
					.dpsp-content-wrapper.dpsp-size-large .dpsp-network-btn.dpsp-has-label:not(.dpsp-has-count){
						max-height: 46px;
					}
				}
			
								.dpsp-button-style-1 .dpsp-networks-btns-content.dpsp-networks-btns-wrapper .dpsp-network-btn:hover .dpsp-network-icon,
								.dpsp-button-style-1 .dpsp-networks-btns-content.dpsp-networks-btns-wrapper .dpsp-network-btn:focus .dpsp-network-icon,
								.dpsp-button-style-1 .dpsp-networks-btns-content.dpsp-networks-btns-wrapper .dpsp-network-btn:hover,
								.dpsp-button-style-1 .dpsp-networks-btns-content.dpsp-networks-btns-wrapper .dpsp-network-btn:focus {
									border-color: #b21711 !important;
									background: #b21711 !important;
								}
							.dpsp-networks-btns-wrapper.dpsp-networks-btns-content .dpsp-network-btn {--networkHover: rgba(178, 23, 17, 0.4); --networkAccent: rgba(178, 23, 17, 1);}
							.dpsp-button-style-7 .dpsp-networks-btns-follow-widget.dpsp-networks-btns-wrapper .dpsp-network-btn:not(:hover):not(:active) {
								--customNetworkColor: #cbc5c5;
								--customNetworkHoverColor: #cbc5c5;
								color: #cbc5c5;
								border-color: #cbc5c5;
							}
							.dpsp-button-style-7 .dpsp-networks-btns-follow-widget.dpsp-networks-btns-wrapper .dpsp-network-btn:not(:active):not(:hover) .dpsp-network-icon {
								border-color: #cbc5c5;
							}
							.dpsp-button-style-7 .dpsp-networks-btns-follow-widget.dpsp-networks-btns-wrapper .dpsp-network-btn:not(:active):not(:hover)  .dpsp-network-icon  .dpsp-network-icon-inner > svg {
								fill: #cbc5c5;
							}
						
							.dpsp-button-style-7 .dpsp-networks-btns-follow-widget.dpsp-networks-btns-wrapper .dpsp-network-btn:hover,
							.dpsp-button-style-7 .dpsp-networks-btns-follow-widget.dpsp-networks-btns-wrapper .dpsp-network-btn:focus {

